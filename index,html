<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Convite Especial</title>
  <style>
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      font-family: Arial, Helvetica, sans-serif;
      overflow: hidden;
      background: radial-gradient(circle at top, #1e3a8a, #0f172a 55%, #020617 100%);
      color: #fff;
    }

    canvas {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: none;
    }

    .screen {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      z-index: 2;
      background: linear-gradient(to bottom, rgba(15, 23, 42, 0.15), rgba(2, 6, 23, 0.45));
      transition: opacity 0.7s ease, visibility 0.7s ease;
    }

    .hidden {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .envelope-wrap {
      text-align: center;
      animation: surgir 0.9s ease;
      width: 100%;
      max-width: 760px;
    }

    .tap-text {
      margin-top: 22px;
      font-size: 1.25rem;
      color: rgba(255,255,255,0.95);
      font-weight: bold;
    }

    .sub-text {
      margin-top: 10px;
      font-size: 1rem;
      color: rgba(255,255,255,0.76);
    }

    .envelope {
      position: relative;
      width: min(92vw, 620px);
      height: min(62vw, 430px);
      margin: 0 auto;
      cursor: pointer;
      transform-style: preserve-3d;
      transition: transform 0.35s ease;
      filter: drop-shadow(0 24px 50px rgba(0,0,0,0.35));
    }

    .envelope:hover {
      transform: scale(1.02);
    }

    .env-back,
    .env-front,
    .env-flap,
    .env-letter,
    .env-title {
      position: absolute;
      inset: 0;
      border-radius: 20px;
    }

    .env-back {
      background: #efd7aa;
      z-index: 1;
    }

    .env-letter {
      left: 7%;
      right: 7%;
      top: 10%;
      bottom: 8%;
      background: transparent;
      color: transparent;
      z-index: 2;
      border-radius: 14px;
      transform: translateY(100%);
      transition: transform 0.95s ease;
      display: block;
      box-shadow: none;
      opacity: 0;
      pointer-events: none;
    }

    .env-title {
      inset: auto 0 88px 0;
      z-index: 4;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      font-size: 1.25rem;
      font-weight: bold;
      color: #7a5514;
      text-shadow: 0 1px 0 rgba(255,255,255,0.25);
      pointer-events: none;
    }

    .env-front {
      background: linear-gradient(135deg, #edd2a0, #e2c38a);
      clip-path: polygon(0 100%, 0 43%, 50% 74%, 100% 43%, 100% 100%);
      z-index: 4;
      border-bottom-left-radius: 20px;
      border-bottom-right-radius: 20px;
    }

    .env-flap {
      background: linear-gradient(135deg, #f4deb4, #e9cb94);
      clip-path: polygon(0 0, 50% 62%, 100% 0, 100% 0, 0 0);
      transform-origin: top center;
      z-index: 5;
      transition: transform 0.95s ease;
      backface-visibility: hidden;
    }

    .envelope.open .env-flap {
      transform: rotateX(180deg);
    }

    .envelope.open .env-letter {
      transform: translateY(-8%);
      opacity: 0;
    }

    .envelope.open .env-title {
      opacity: 0;
      transition: opacity 0.25s ease;
    }

    .card {
      width: min(92vw, 720px);
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-radius: 24px;
      padding: 36px 30px;
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.35);
      text-align: center;
      animation: surgir 0.9s ease;
    }

    @keyframes surgir {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.96);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .tag {
      display: inline-block;
      margin-bottom: 14px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      font-size: 0.9rem;
      letter-spacing: 0.04em;
    }

    h1 {
      margin: 0 0 14px;
      font-size: clamp(1.8rem, 4vw, 2.9rem);
      line-height: 1.15;
    }

    p {
      margin: 0 0 14px;
      font-size: 1.08rem;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.95);
    }

    .question {
      margin: 24px 0 26px;
      font-size: clamp(1.2rem, 2.5vw, 1.55rem);
      font-weight: bold;
    }

    .buttons {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    button {
      border: none;
      border-radius: 14px;
      padding: 14px 28px;
      min-width: 170px;
      font-size: 1rem;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
    }

    button:hover { transform: translateY(-2px); }
    .yes { background: #22c55e; color: #082f15; }
    .no { background: #ef4444; color: #fff; }

    .result {
      margin-top: 22px;
      padding: 14px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 0.98rem;
      display: none;
    }

    .small {
      margin-top: 18px;
      font-size: 0.86rem;
      color: rgba(255, 255, 255, 0.72);
    }

    @media (max-width: 700px) {
      .envelope {
        width: min(92vw, 500px);
        height: min(66vw, 340px);
      }
    }

    @media (max-width: 560px) {
      .card { padding: 26px 18px; }
      button { width: 100%; }
      .buttons { flex-direction: column; }
      .tap-text { font-size: 1.05rem; }
      .sub-text { font-size: 0.92rem; }
      .envelope { height: min(68vw, 290px); }
    }
  </style>
</head>
<body>
  <canvas id="fireworks"></canvas>

  <div class="screen" id="envelopeScreen">
    <div class="envelope-wrap">
      <div class="envelope" id="envelope">
        <div class="env-back"></div>
        <div class="env-letter"></div>
        <div class="env-title">Convite especial</div>
        <div class="env-front"></div>
        <div class="env-flap"></div>
      </div>
      <div class="tap-text">Clique no envelope para abrir</div>
      <div class="sub-text">Uma surpresa especial foi preparada para o senhor</div>
    </div>
  </div>

  <div class="screen hidden" id="inviteScreen">
    <div class="card">
      <div class="tag">Convite Especial</div>
      <h1>Prof. Dr. :Ramasio Ferreira de Melo</h1>
      <p>
        A turma de formandos de 2026, com grande carinho, respeito e admiração, convida o senhor para ser o padrinho da nossa turma.
      </p>
      <p>
        Sua presença em nossa trajetória acadêmica representa incentivo, aprendizado e inspiração. Por isso, este convite foi preparado de forma especial para expressar o quanto sua participação será importante nesse momento tão marcante.
      </p>
      <p class="question">O senhor aceita ser padrinho da turma de formandos do Curso de Licenciatura em Computação de 2026?</p>

      <div class="buttons">
        <button class="yes" id="acceptBtn">Aceito</button>
        <button class="no" id="declineBtn">Não aceito</button>
      </div>

      <div class="result" id="resultBox"></div>

      <div class="small">
        Ao confirmar, a resposta pode ser registrada automaticamente apenas se o site estiver ligado a um serviço externo.
      </div>
    </div>
  </div>

  <script>
    const PROFESSOR_NOME = 'Prof. Dr. :Ramasio Ferreira de Melo';
    const DESTINO_WHATSAPP = '5594992267248';

    // Sons gerados no próprio HTML via Web Audio API
    let audioCtx = null;
    let fireworksAudioInterval = null;

    function ensureAudioContext() {
      if (!audioCtx) {
        const AudioContextClass = window.AudioContext || window.webkitAudioContext;
        audioCtx = new AudioContextClass();
      }
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
    }

    function playEnvelopeSound() {
      ensureAudioContext();
      const now = audioCtx.currentTime;

      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      const filter = audioCtx.createBiquadFilter();

      osc.type = 'triangle';
      osc.frequency.setValueAtTime(520, now);
      osc.frequency.exponentialRampToValueAtTime(240, now + 0.18);
      osc.frequency.exponentialRampToValueAtTime(160, now + 0.42);

      filter.type = 'lowpass';
      filter.frequency.setValueAtTime(1800, now);

      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.linearRampToValueAtTime(0.1, now + 0.03);
      gain.gain.exponentialRampToValueAtTime(0.018, now + 0.22);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.5);

      osc.connect(filter);
      filter.connect(gain);
      gain.connect(audioCtx.destination);

      osc.start(now);
      osc.stop(now + 0.5);

      const noiseBuffer = audioCtx.createBuffer(1, audioCtx.sampleRate * 0.35, audioCtx.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      for (let i = 0; i < data.length; i++) {
        data[i] = (Math.random() * 2 - 1) * 0.18;
      }

      const noise = audioCtx.createBufferSource();
      const noiseFilter = audioCtx.createBiquadFilter();
      const noiseGain = audioCtx.createGain();
      noise.buffer = noiseBuffer;
      noiseFilter.type = 'bandpass';
      noiseFilter.frequency.setValueAtTime(900, now);
      noiseFilter.Q.setValueAtTime(0.7, now);
      noiseGain.gain.setValueAtTime(0.0001, now);
      noiseGain.gain.linearRampToValueAtTime(0.05, now + 0.02);
      noiseGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.35);

      noise.connect(noiseFilter);
      noiseFilter.connect(noiseGain);
      noiseGain.connect(audioCtx.destination);
      noise.start(now);
      noise.stop(now + 0.35);
    }

    function playFireworkBurstSound() {
      ensureAudioContext();
      const now = audioCtx.currentTime;

      const noiseBuffer = audioCtx.createBuffer(1, audioCtx.sampleRate * 0.9, audioCtx.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      for (let i = 0; i < data.length; i++) {
        data[i] = Math.random() * 2 - 1;
      }

      const source = audioCtx.createBufferSource();
      const bandpass = audioCtx.createBiquadFilter();
      const lowpass = audioCtx.createBiquadFilter();
      const gain = audioCtx.createGain();

      source.buffer = noiseBuffer;
      bandpass.type = 'bandpass';
      bandpass.frequency.setValueAtTime(650, now);
      bandpass.Q.setValueAtTime(0.8, now);
      lowpass.type = 'lowpass';
      lowpass.frequency.setValueAtTime(2200, now);

      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.linearRampToValueAtTime(0.04, now + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.018, now + 0.18);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.9);

      source.connect(bandpass);
      bandpass.connect(lowpass);
      lowpass.connect(gain);
      gain.connect(audioCtx.destination);

      source.start(now);
      source.stop(now + 0.9);
    }

    function startFireworksSoundLoop() {
      if (fireworksAudioInterval) return;
      fireworksAudioInterval = setInterval(() => {
        const bursts = Math.floor(Math.random() * 2) + 1;
        for (let i = 0; i < bursts; i++) {
          setTimeout(playFireworkBurstSound, i * 220);
        }
      }, 1000);
    }

    const canvas = document.getElementById('fireworks');
    const ctx = canvas.getContext('2d');
    let particles = [];
    let fireworksStarted = false;
    let fireworksInterval = null;

    function resizeCanvas() {
      canvas.width = window.innerWidth * devicePixelRatio;
      canvas.height = window.innerHeight * devicePixelRatio;
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    class Particle {
      constructor(x, y, color, angle, speed) {
        this.x = x;
        this.y = y;
        this.color = color;
        this.angle = angle;
        this.speed = speed;
        this.alpha = 1;
        this.gravity = 0.04;
        this.decay = Math.random() * 0.012 + 0.008;
        this.size = Math.random() * 2.5 + 1.2;
      }
      update() {
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;
        this.speed *= 0.985;
        this.y += this.gravity * 12;
        this.alpha -= this.decay;
      }
      draw() {
        ctx.save();
        ctx.globalAlpha = Math.max(this.alpha, 0);
        ctx.beginPath();
        ctx.fillStyle = this.color;
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();
        ctx.restore();
      }
    }

    function randomColor() {
      const colors = ['#fbbf24', '#60a5fa', '#f472b6', '#34d399', '#f87171', '#c084fc'];
      return colors[Math.floor(Math.random() * colors.length)];
    }

    function explode(x, y) {
      const count = 60 + Math.floor(Math.random() * 20);
      const color = randomColor();
      for (let i = 0; i < count; i++) {
        const angle = (Math.PI * 2 * i) / count;
        const speed = Math.random() * 3.5 + 1.5;
        particles.push(new Particle(x, y, color, angle, speed));
      }
    }

    function launchFirework() {
      const x = Math.random() * window.innerWidth * 0.8 + window.innerWidth * 0.1;
      const y = Math.random() * window.innerHeight * 0.35 + 80;
      explode(x, y);
    }

    function animate() {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      particles = particles.filter(p => p.alpha > 0);
      for (const p of particles) {
        p.update();
        p.draw();
      }
      requestAnimationFrame(animate);
    }
    animate();

    function startContinuousFireworks() {
      if (fireworksStarted) return;
      fireworksStarted = true;

      for (let i = 0; i < 10; i++) {
        setTimeout(() => {
          launchFirework();
          if (i < 4) playFireworkBurstSound();
        }, i * 250);
      }

      fireworksInterval = setInterval(() => {
        const bursts = Math.floor(Math.random() * 3) + 1;
        for (let i = 0; i < bursts; i++) {
          setTimeout(() => {
            launchFirework();
          }, i * 180);
        }
      }, 900);

      startFireworksSoundLoop();
    }

    const envelope = document.getElementById('envelope');
    const envelopeScreen = document.getElementById('envelopeScreen');
    const inviteScreen = document.getElementById('inviteScreen');
    const acceptBtn = document.getElementById('acceptBtn');
    const declineBtn = document.getElementById('declineBtn');
    const resultBox = document.getElementById('resultBox');

    function showMessage(message) {
      resultBox.style.display = 'block';
      resultBox.innerHTML = message;
    }

    envelope.addEventListener('click', () => {
      envelope.classList.add('open');
      setTimeout(() => {
        envelopeScreen.classList.add('hidden');
        inviteScreen.classList.remove('hidden');
        playEnvelopeSound();
        startContinuousFireworks();
      }, 950);
    });

    function enviarWhatsApp(resposta) {
      const dataHora = new Date().toLocaleString('pt-BR');
      const texto = encodeURIComponent(
        `Confirmação do convite de padrinho da turma de formandos de 2026

Professor: ${PROFESSOR_NOME}
Resposta: ${resposta}
Data/Hora: ${dataHora}`
      );
      localStorage.setItem('convite_padrinho_resposta', JSON.stringify({
        professor: PROFESSOR_NOME,
        resposta,
        dataHora
      }));
      window.open(`https://wa.me/${DESTINO_WHATSAPP}?text=${texto}`, '_blank');
      showMessage(`Resposta registrada: <strong>${resposta}</strong>. O WhatsApp foi aberto com a confirmação pronta.`);
    }

    acceptBtn.addEventListener('click', () => {
      playFireworkBurstSound();
      enviarWhatsApp('Aceito ser padrinho da turma');
      for (let i = 0; i < 6; i++) {
        setTimeout(() => {
          launchFirework();
          if (i < 3) playFireworkBurstSound();
        }, i * 180);
      }
    });

    declineBtn.addEventListener('click', () => {
      enviarWhatsApp('Não aceito ser padrinho da turma');
    });
  </script>
</body>
</html>
